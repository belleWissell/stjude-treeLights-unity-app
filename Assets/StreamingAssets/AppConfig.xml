        <MasterAudioLevel>85</MasterAudioLevel> <!-- int betw 0-100 -->
        <audioFileFolder>..//RESOURCES//audio//</audioFileFolder>
        <audio>
            <audioID>runOfShow</audioID>
            <audioMediaFile>Remembrance_Experience_Demo_1.wav</audioMediaFile> <!-- located in content folder //RESOURCES//audio//UIUX// -->
            <doLoopAudio>false</doLoopAudio>
            <audioLoopPoint>0.995</audioLoopPoint>  <!-- percentage of audio to play before looping  float betw 0-1 -->
        </audio>
    </audioSettings>
</appSettings>